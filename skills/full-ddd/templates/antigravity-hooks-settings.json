{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "Write|Edit|Bash|Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "cat docs/ddd/ddd-progress.md 2>/dev/null | head -20 || true",
            "name": "ddd-progress-check",
            "description": "Display current DDD workflow progress before each tool execution."
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "edit_file|write_file|create_file|write_to_file",
        "hooks": [
          {
            "type": "command",
            "command": "sh skills/full-ddd/scripts/check-persistence.sh 2>/dev/null || true",
            "name": "ddd-persistence-check",
            "description": "Warn if completed phases lack persisted artifact files."
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh skills/full-ddd/scripts/verify-artifacts.sh 2>/dev/null || true",
            "name": "ddd-artifact-verify",
            "description": "Verify all approved phases have persisted artifacts before session ends."
          }
        ]
      }
    ]
  }
}
